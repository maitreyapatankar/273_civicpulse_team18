# CivicPulse — environment template
#
# SETUP:
#   cp .env.example .env
#   Fill in every value marked REQUIRED before running docker compose up.
#   See README.md → "Required Credentials" for what each key does.
#
# The internal connection strings below are pre-filled for docker-compose.
# Only change them if you're running services outside of Docker.

# ── Internal (docker-compose defaults — no changes needed) ────────────────────
DATABASE_URL=postgresql://civic:civic@postgres:5432/civicpulse
REDIS_URL=redis://redis:6379/0
API_BASE_URL=http://api:8000

# ── Service 1 — API Gateway ───────────────────────────────────────────────────
OFFICER_JWT_SECRET=                  # REQUIRED — JWT secret for officer/admin tokens
CITIZEN_JWT_SECRET=                  # REQUIRED — JWT secret for citizen tokens
ADMIN_USERNAME=admin                 # REQUIRED — admin bootstrap username
ADMIN_PASSWORD=adminP                # REQUIRED — admin bootstrap password

S3_BUCKET=                           # REQUIRED for image uploads — your S3/R2 bucket name
S3_REGION=us-east-1                  # change if using a different region or Cloudflare R2
AWS_ACCESS_KEY_ID=                   # REQUIRED for image uploads — IAM key with s3:PutObject
AWS_SECRET_ACCESS_KEY=               # REQUIRED for image uploads — paired IAM secret

# ── Service 2 — AI Core ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                   # REQUIRED — Claude API (classify, urgency, work orders)
OPENAI_API_KEY=                      # REQUIRED — text-embedding-3-small for deduplication
PINECONE_API_KEY=                    # REQUIRED — Pinecone vector DB for deduplication
PINECONE_INDEX=civicpulse-reports    # create this index in Pinecone console before first run

# ── Service 5 — Notifications ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=                  # REQUIRED for SMS — Twilio console → Account SID
TWILIO_AUTH_TOKEN=                   # REQUIRED for SMS — Twilio console → Auth Token
TWILIO_FROM_NUMBER=                  # REQUIRED for SMS — your Twilio number e.g. +12025551234

# ── Frontend (build-time) ─────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
